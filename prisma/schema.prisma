generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  birthDate String
  email     String   @unique
  password  String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  refreshToken  String?
  role          String   @default("patient")

  appointments Appointment[]
}

model Doctor {
  id                  String   @id @default(uuid())
  name                String
  password            String
  medicalSpecialty    String
  medicalRegistration String   @unique
  email               String   @unique
  phone               String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  refreshToken  String?
  role          String   @default("doctor")

  appointments Appointment[]
}

model Appointment {
  id        String   @id @default(uuid())
  date      DateTime
  doctorId  String
  patientId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  doctor        Doctor         @relation(fields: [doctorId], references: [id])
  patient       Patient        @relation(fields: [patientId], references: [id])
  prescriptions Prescription[]
}

model Prescription {
  id            String    @id @default(uuid())
  date          DateTime?
  appointmentId String
  medicine      String
  dosage        String
  instructions  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  file          String?

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  refreshToken  String?
  role          String   @default("admin")
}
